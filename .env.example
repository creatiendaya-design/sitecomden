# Plantilla de variables de entorno — copiar a `.env` y rellenar con valores reales.
# Este archivo SÍ se sube a git; `.env` está en .gitignore.
# Next.js NO lee este archivo en runtime, solo `.env` / `.env.local`.

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Culqi — Pagos con tarjeta
NEXT_PUBLIC_CULQI_PUBLIC_KEY=pk_test_REPLACE_ME
CULQI_SECRET_KEY=sk_test_REPLACE_ME
CULQI_WEBHOOK_SECRET=

# Vercel Blob — Almacenamiento de archivos (imágenes)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_REPLACE_ME"

# Cloudflare Stream — Hosting de VIDEO (transcodificación + streaming adaptativo).
# OPCIONAL: si están vacíos, los videos suben a Vercel Blob como fallback.
# Cuando completes estas 2 variables, la librería de archivos enruta los
# videos a Cloudflare automáticamente (subida directa desde el navegador).
#   - CLOUDFLARE_ACCOUNT_ID: dashboard de Cloudflare (esquina de la URL / Stream).
#   - CLOUDFLARE_STREAM_API_TOKEN: token con permiso "Stream: Edit".
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
# OPCIONAL: tu subdominio de reproducción (ej: customer-abc123.cloudflarestream.com).
# Si lo dejas vacío se usa el dominio público videodelivery.net.
CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=

# Resend — Envío de emails transaccionales
RESEND_API_KEY="re_REPLACE_ME"

# URL pública de la app (usada en emails, redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Credenciales del Super Admin creado por `npx tsx prisma/seed-permissions.ts`.
# OBLIGATORIO para crear el admin (contraseña mín. 8 caracteres). Sin
# SEED_ADMIN_PASSWORD el seed omite la creación (ya no hay contraseña por defecto).
SEED_ADMIN_EMAIL=admin@tudominio.com
SEED_ADMIN_PASSWORD=

# Clerk v6+ — Autenticación de clientes
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Upstash Redis — Rate limiting
UPSTASH_REDIS_REST_URL="https://YOUR-INSTANCE.upstash.io"
UPSTASH_REDIS_REST_TOKEN="REPLACE_ME"

# SUNAT Electronic Invoicing — clave de cifrado AES-256 (32 bytes en hex = 64 chars)
# Generar con: openssl rand -hex 32
SUNAT_ENCRYPTION_KEY=

# Sentry — Error tracking (opcional pero MUY recomendado para producción)
# Si NEXT_PUBLIC_SENTRY_DSN está vacío, el SDK se inicializa como no-op.
# Crear proyecto en https://sentry.io/ y copiar el DSN.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Para subir source maps en producción (opcional). Sin estos 3 vars,
# next.config.ts ignora el wrapper de Sentry y los stack traces quedan minificados.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
