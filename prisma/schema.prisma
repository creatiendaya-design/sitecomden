generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  image       String?

  metaTitle       String?
  metaDescription String?

  collectionType CollectionType @default(MANUAL)

  parentId String?
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")

  order  Int     @default(0)
  active Boolean @default(true)

  /// When true, the storefront hides the auto-generated product grid on the
  /// category page so categoryBlocks can render a fully custom landing
  /// (Plan 7). Defaults to false — grid renders below the blocks.
  hideProductGrid Boolean @default(false)

  products         ProductCategory[]
  conditions       CategoryCondition[]
  categoryBlocks   CategoryBlock[]
  promotionTargets PromotionCategory[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  /// Soft-delete tombstone. See Product.deletedAt for rationale.
  deletedAt DateTime?

  @@index([slug])
  @@index([active])
  @@index([parentId])
  @@index([collectionType])
  @@index([deletedAt])
}

/// Optional landing blocks rendered above the product grid on a category
/// page. Mirrors the PageBlock model — same renderer, same content shape,
/// but scoped to a Category instead of a Page (Plan 7).
model CategoryBlock {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  /// Block type id from lib/blocks/registry.ts (e.g. "HERO", "GALLERY").
  /// String — not enum — so adding a block type does not require migration.
  /// Validated in runtime by the server actions via getBlockDefinition().
  type       String
  position   Int
  content    Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  /// Optimistic-locking version. Incremented on every update via
  /// `updateMany` with `where: { id, version }`. See
  /// docs/superpowers/guides/concurrency-and-locking.md (Plan 18).
  version    Int      @default(0)

  @@index([categoryId, position])
}

enum CollectionType {
  MANUAL
  SMART
}

model CategoryCondition {
  id         String @id @default(cuid())
  categoryId String

  field String

  operator String

  value String

  relation ConditionRelation @default(AND)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([categoryId])
}

enum ConditionRelation {
  AND
  OR
}

model Product {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  description      String?         @db.Text
  shortDescription String?         @db.Text
  basePrice        Decimal         @db.Decimal(10, 2)
  compareAtPrice   Decimal?        @db.Decimal(10, 2)
  sku              String?         @unique
  stock            Int             @default(0)
  images           Json            @default("[]")
  hasVariants      Boolean         @default(false)
  template         ProductTemplate @default(STANDARD)
  checkoutMode     CheckoutMode    @default(STANDARD)
  metaTitle        String?
  metaDescription  String?
  featured         Boolean         @default(false)
  active           Boolean         @default(true)
  weight           Decimal?        @db.Decimal(8, 2)
  igvType          IgvType         @default(GRAVADO)

  /// Denormalized review aggregates (Fase 4). Recomputed from APPROVED
  /// reviews whenever a review is approved/unapproved/edited/deleted, so the
  /// product grid can show stars without a per-card aggregate query.
  averageRating    Float           @default(0)
  reviewCount      Int             @default(0)

  categories ProductCategory[]

  variants                    ProductVariant[]
  options                     ProductOption[]
  orderItems                  OrderItem[]
  reviews                     ProductReview[]
  cartItems                   CartItem[]
  inventoryMovements          InventoryMovement[]
  landingBlocks               LandingBlock[]
  landingTemplateId           String?
  landingTemplate             LandingTemplate?      @relation(fields: [landingTemplateId], references: [id], onDelete: SetNull)
  customizableTemplateId      String?
  customizableTemplate        CustomizableTemplate? @relation(fields: [customizableTemplateId], references: [id], onDelete: SetNull)
  customizableMockupOverrides Json?
  sizeGuideId                 String?
  sizeGuide                   SizeGuide?            @relation(fields: [sizeGuideId], references: [id], onDelete: SetNull)
  codFormTemplateId           String?
  codFormTemplate             CodFormTemplate?      @relation(fields: [codFormTemplateId], references: [id], onDelete: SetNull)
  shippingRestriction         Json?
  promotionTargets            PromotionProduct[]
  /// Cross-sell / "frequently bought together" curation (manual side of the
  /// hybrid recommender). `relationsFrom` = picks the admin set on THIS
  /// product; `relationsTo` = the inverse (this product is recommended by X).
  relationsFrom               ProductRelation[]     @relation("ProductRelationsFrom")
  relationsTo                 ProductRelation[]     @relation("ProductRelationsTo")
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  /// Optimistic-locking version (Plan 18). Applies to content edits
  /// (name, description, SEO, images, template bindings). Stock changes
  /// use atomic `{ increment }` / `{ decrement }` and do NOT bump this.
  version                     Int                   @default(0)
  /// Soft-delete tombstone. Null = live row. Non-null = the admin removed
  /// the product but its history (OrderItem snapshots, audit trail) must
  /// remain intact. Storefront queries must filter `deletedAt: null`.
  deletedAt                   DateTime?

  @@index([slug])
  @@index([active])
  @@index([featured])
  @@index([template])
  @@index([customizableTemplateId])
  @@index([sizeGuideId])
  @@index([codFormTemplateId])
  @@index([deletedAt])
}

/// Manual product↔product curation for cross-sell / "comprados juntos".
/// The recommender is hybrid: this table is the highest-priority source;
/// when a product has no rows here, the resolver falls back to automatic
/// co-purchase inference (order history) and then to same-category.
model ProductRelation {
  id               String              @id @default(cuid())
  productId        String
  relatedProductId String
  type             ProductRelationType @default(BOUGHT_TOGETHER)
  /// Admin-controlled display order (lower = first).
  position         Int                 @default(0)
  createdAt        DateTime            @default(now())

  product        Product @relation("ProductRelationsFrom", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("ProductRelationsTo", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId, type])
  @@index([productId, type, position])
  @@index([relatedProductId])
}

enum ProductRelationType {
  BOUGHT_TOGETHER
  CROSS_SELL
}

model LandingBlock {
  id                    String   @id @default(cuid())
  productId             String
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// See CategoryBlock.type — string, validated against the registry.
  type                  String
  position              Int
  content               Json     @default("{}")
  sourceTemplateBlockId String?
  detached              Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  /// Optimistic-locking version (Plan 18).
  version               Int      @default(0)

  @@index([productId, position])
  @@index([sourceTemplateBlockId])
}

enum ProductTemplate {
  STANDARD
  LANDING
  MINIMAL
  GALLERY
}

// Note: the `LandingBlockType` enum was dropped on 2026-05-27. Block
// types are now plain strings validated in runtime by the server actions
// against `lib/blocks/registry.ts`. This mirrors how ThemeSection.type
// works (Plan 16) and means adding a new block type only requires
// registering it in the registry — no Prisma migration.

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
}

model ProductOption {
  id           String               @id @default(cuid())
  productId    String
  name         String
  position     Int                  @default(0)
  displayStyle OptionDisplayStyle   @default(DROPDOWN)
  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values       ProductOptionValue[]

  @@index([productId])
}

model ProductOptionValue {
  id          String        @id @default(cuid())
  optionId    String
  value       String
  position    Int           @default(0)
  swatchType  SwatchType    @default(NONE)
  colorHex    String?
  swatchImage String?
  option      ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([optionId])
}

model ProductVariant {
  id                 String              @id @default(cuid())
  productId          String
  sku                String              @unique
  barcode            String?
  options            Json
  price              Decimal             @db.Decimal(10, 2)
  compareAtPrice     Decimal?            @db.Decimal(10, 2)
  stock              Int                 @default(0)
  lowStockAlert      Int                 @default(5)
  weight             Decimal?            @db.Decimal(8, 2)
  image              String?
  active             Boolean             @default(true)
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]
  cartItems          CartItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  /// Optimistic-locking version (Plan 18). Covers content fields
  /// (price, SKU, options, image, active). Stock uses atomic
  /// `{ increment }` / `{ decrement }` and does NOT bump this.
  version            Int                 @default(0)

  @@index([productId])
  @@index([sku])
  @@index([active])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique @default(cuid())
  orderSeq    Int         @default(autoincrement())
  viewToken   String      @unique @default(cuid())
  subtotal    Decimal     @db.Decimal(10, 2)
  shipping    Decimal     @default(0) @db.Decimal(10, 2)
  discount    Decimal     @default(0) @db.Decimal(10, 2)
  tax         Decimal     @default(0) @db.Decimal(10, 2)
  total       Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  pointsEarned Int @default(0)

  pointsUsed Int @default(0)

  customerTier LoyaltyTier?

  paymentStatus      PaymentStatus       @default(PENDING)
  fulfillmentStatus  FulfillmentStatus   @default(UNFULFILLED)
  customerName       String
  customerEmail      String
  customerPhone      String
  customerDni        String?
  customerType       String              @default("person")
  billingAddress     Json
  shippingAddress    Json
  shippingMethod     String?
  shippingCourier    String?
  trackingNumber     String?
  estimatedDelivery  DateTime?
  paymentMethod      PaymentMethod
  paymentProvider    String?
  paymentId          String?             @unique
  paymentDetails     Json?
  items              OrderItem[]
  pendingPayment     PendingPayment?
  couponCode         String?
  couponDiscount     Decimal?            @db.Decimal(10, 2)
  customerNotes      String?             @db.Text
  documentType       DocumentType?
  buyerRuc           String?
  buyerRazonSocial   String?
  buyerFiscalAddress String?             @db.Text
  electronicDocument ElectronicDocument?
  adminNotes         String?             @db.Text
  paidAt             DateTime?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  /// When the "leave a review" post-purchase email was sent for this order.
  /// Null = not sent yet; set so the cron never emails the same order twice.
  reviewRequestSentAt DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  /// Optimistic-locking version (Plan 18). Two admins updating the same
  /// order status concurrently — for example one marking it PAID while the
  /// other CANCELS it — should produce a conflict, not silent loss.
  version            Int                 @default(0)

  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([fulfillmentStatus])
  @@index([customerEmail])
  @@index([createdAt])
}

model OrderItem {
  id                 String          @id @default(cuid())
  orderId            String
  productId          String?
  variantId          String?
  name               String
  variantName        String?
  price              Decimal         @db.Decimal(10, 2)
  quantity           Int
  image              String?
  sku                String?
  variantOptions     Json?
  customDesign       Json?
  customDesignImages Json?
  order              Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant            ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model PendingPayment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  method          PaymentMethod
  amount          Decimal       @db.Decimal(10, 2)
  reference       String?
  proofImage      String?
  status          String        @default("pending")
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectionReason String?
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
}

enum DocumentStatus {
  PENDING
  ISSUED
  CANCELLED
  ERROR
}

model ElectronicDocument {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type       DocumentType
  series     String
  number     Int
  fullNumber String

  status DocumentStatus @default(PENDING)

  xmlContent   String? @db.Text
  pdfUrl       String?
  xmlUrl       String?
  cdrUrl       String?
  sunatCode    Int?
  hash         String?
  nubefactId   String?
  errorMessage String?

  issuedAt           DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([series, number])
  @@index([status])
  @@index([type])
  @@index([fullNumber])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  VERIFYING
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIAL
  FULFILLED
}

enum PaymentMethod {
  CARD
  PAYPAL
  YAPE
  PLIN
  MERCADOPAGO
  COD
}

enum CheckoutMode {
  STANDARD
  COD_ONLY
  COD_AND_CART
}

enum CodFormBlockType {
  HEADER
  CART_ITEMS
  SHIPPING_OPTIONS
  ORDER_SUMMARY
  SUBMIT_BUTTON
  FIELD_NAME
  FIELD_PHONE
  FIELD_EMAIL
  FIELD_DNI
  FIELD_ADDRESS
  FIELD_ADDRESS_2
  FIELD_PROVINCE
  FIELD_CITY
  FIELD_REFERENCE
  FIELD_NOTES
}

enum PostSubmitAction {
  INLINE_THANK_YOU
  WHATSAPP_REDIRECT
  THANK_YOU_PAGE
}

enum IgvType {
  GRAVADO
  EXONERADO
  INAFECTO
}

enum DocumentType {
  BOLETA
  FACTURA
}

model Coupon {
  id                String     @id @default(cuid())
  code              String     @unique
  description       String?
  type              CouponType
  value             Decimal    @db.Decimal(10, 2)
  minPurchase       Decimal?   @db.Decimal(10, 2)
  maxDiscount       Decimal?   @db.Decimal(10, 2)
  usageLimit        Int?
  usageLimitPerUser Int?
  /// Counter incremented atomically at checkout via `{ increment: 1 }`.
  /// NOT covered by optimistic locking — always-correct accumulation.
  usageCount        Int        @default(0)
  startsAt          DateTime?
  expiresAt         DateTime?
  active            Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  /// Optimistic-locking version (Plan 18). Covers admin edits to the
  /// coupon definition (value, limits, dates). `usageCount` bumps
  /// separately via atomic increment.
  version           Int        @default(0)
  /// Soft-delete tombstone. Coupons can be referenced from past Orders via
  /// snapshot fields; tombstoning preserves that lookup chain.
  deletedAt         DateTime?

  @@index([code])
  @@index([active])
  @@index([deletedAt])
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

model Promotion {
  id                   String               @id @default(cuid())
  name                 String
  type                 ProductPromotionType
  active               Boolean              @default(true)
  priority             Int                  @default(0)
  config               Json                 @default("{}")
  startsAt             DateTime?
  expiresAt            DateTime?
  usageCount           Int                  @default(0)
  /// Sum of discount amounts applied across all orders that used this
  /// promotion (in PEN). For FREE_GIFT it accumulates the basePrice of
  /// the gift handed out per order.
  totalDiscountApplied Decimal              @default(0) @db.Decimal(12, 2)
  productTargets       PromotionProduct[]
  categoryTargets      PromotionCategory[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  /// Soft-delete tombstone. Preserves analytics on
  /// `totalDiscountApplied` and `usageCount` after retirement.
  deletedAt            DateTime?

  @@index([active])
  @@index([type])
  @@index([deletedAt])
}

model PromotionProduct {
  promotionId String
  productId   String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([promotionId, productId])
  @@index([productId])
  @@index([promotionId])
}

model PromotionCategory {
  promotionId String
  categoryId  String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([promotionId, categoryId])
  @@index([categoryId])
  @@index([promotionId])
}

enum ProductPromotionType {
  VOLUME
  SUBSCRIPTION
  FREE_GIFT
  BUNDLE
}

model InventoryMovement {
  id        String                @id @default(cuid())
  variantId String?
  productId String?
  type      InventoryMovementType
  quantity  Int
  reason    String?
  reference String?
  userId    String?
  variant   ProductVariant?       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  product   Product?              @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime              @default(now())

  @@index([variantId])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

enum InventoryMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  DAMAGE
}

model Cart {
  id          String     @id @default(cuid())
  sessionId   String     @unique
  userId      String?
  items       CartItem[]
  abandonedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([sessionId])
  @@index([userId])
}

model CartItem {
  id        String          @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

model ProductReview {
  id            String   @id @default(cuid())
  productId     String
  orderId       String?
  customerName  String
  customerEmail String
  rating        Int
  title         String?
  comment       String?  @db.Text
  images        String[]
  verified      Boolean  @default(false)
  approved      Boolean  @default(false)
  /// Optional public reply from the store, shown under the review on the
  /// storefront. `repliedBy` is the admin User id (plain string, not a
  /// relation, so deleting a user never cascades to review history).
  reply         String?  @db.Text
  repliedAt     DateTime?
  repliedBy     String?
  /// Set when a reward coupon was issued for this review (Fase 4). Guarantees
  /// at most one coupon per review — the approval flow checks this before
  /// generating. Plain string (Coupon id), not a relation, to avoid cascade
  /// coupling with coupon soft-deletes.
  rewardCouponId String?
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([approved])
  @@index([verified])
}

model Permission {
  id String @id @default(cuid())

  key String @unique

  name        String
  description String?

  module String
  action String

  roles RolePermission[]
  users UserPermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([module])
  @@index([action])
  @@index([key])
}

model Role {
  id String @id @default(cuid())

  name        String  @unique
  slug        String  @unique
  description String?

  level Int @default(0)

  color String? @default("#6366f1")

  isSystem Boolean @default(false)
  active   Boolean @default(true)

  permissions RolePermission[]
  users       User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Optimistic-locking version (Plan 18). Two super-admins editing
  /// the same role's permissions concurrently must collide cleanly.
  version   Int      @default(0)

  @@index([slug])
  @@index([level])
  @@index([active])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserPermission {
  id           String @id @default(cuid())
  userId       String
  permissionId String

  type PermissionType @default(GRANT)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

enum PermissionType {
  GRANT
  DENY
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  password          String
  name              String
  roleId            String?
  role              Role?            @relation(fields: [roleId], references: [id])
  customPermissions UserPermission[]
  sessions          AdminSession[]
  active            Boolean          @default(true)
  lastLogin         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  /// Soft-delete tombstone. AuditLog references userId as a plain string
  /// (no FK) so we *could* hard-delete here, but keeping a tombstone lets
  /// us still resolve "who did this?" lookups in the admin UI.
  /// Login/permission checks must filter `deletedAt: null`.
  deletedAt         DateTime?

  @@index([email])
  @@index([active])
  @@index([roleId])
  @@index([deletedAt])
}

// Server-side admin sessions. The cookie carries an opaque random token
// (32 random bytes hex-encoded) that maps to a row here. Storing the user.id
// directly in the cookie would let anyone who learned a user's id authenticate
// as them and there would be no way to invalidate a leaked cookie.
//
// On password change or admin revocation, delete the user's rows here to log
// them out everywhere immediately.
model AdminSession {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?

  @@index([userId])
  @@index([expiresAt])
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  category    String?
  updatedAt   DateTime @updatedAt
  /// Optimistic-locking version (Plan 18). Settings are frequently
  /// touched by multiple admins (Culqi keys, SUNAT config, email
  /// templates) — silent overwrites here can break payments.
  version     Int      @default(0)

  @@index([key])
  @@index([category])
}

/// Media library (Shopify-style "Contenido → Archivos"). Tracks every blob
/// uploaded through /api/upload so admins can browse, search, edit the alt
/// text / display name, and delete files from one place.
///
/// The blob `url` stays STABLE on metadata edits: renaming a blob would mean
/// copying to a new URL and breaking every product / page / block that already
/// references it. So editing the "filename" only touches `displayName` here —
/// the actual stored file is never renamed.
model MediaFile {
  id              String    @id @default(cuid())
  /// Public Vercel Blob URL — the stable identifier referenced across the app.
  url             String    @unique
  /// Blob pathname, e.g. "products/1700000000-ab12cd.jpg".
  pathname        String
  /// Original filename at upload time (e.g. "foto-zapatos.jpg").
  filename        String
  /// Admin-editable display name for organization. Falls back to `filename`.
  displayName     String?
  /// SEO alt text (images only).
  alt             String?
  mimeType        String
  /// Size in bytes.
  size            Int
  width           Int?
  height          Int?
  isImage         Boolean   @default(true)
  /// Storage backend: "vercel_blob" (images + fallback videos) or
  /// "cloudflare_stream" (videos with transcoding + adaptive streaming).
  provider        String    @default("vercel_blob")
  /// Provider-side id. For Cloudflare Stream this is the video `uid`; null for
  /// plain Vercel Blob uploads (the `url` is the identifier there).
  providerId      String?
  /// Poster/thumbnail URL (Cloudflare Stream videos). Images derive their own.
  thumbnailUrl    String?
  /// Processing state for async backends: "processing" | "ready" | "error".
  /// Null for Vercel Blob (always immediately available).
  status          String?
  /// Video duration in seconds, when known.
  durationSeconds Int?
  /// Admin user id that uploaded it (plain String, no FK — survives user deletion).
  uploadedById    String?
  uploadedAt      DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  /// Soft-delete tombstone. Set when removed from the library.
  deletedAt       DateTime?
  /// Optimistic-locking version (Plan 18 convention).
  version         Int       @default(0)

  @@index([deletedAt, uploadedAt])
  @@index([isImage])
  @@index([mimeType])
  @@index([providerId])
}

