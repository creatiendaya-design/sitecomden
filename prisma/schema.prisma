/// A user-editable static page (Nosotros, Términos, FAQ, etc.) authored
/// via the page builder. The storefront resolves /<slug> to the active
/// Page when one exists, falling back to hardcoded route files otherwise.
model Page {
  id                String            @id @default(cuid())
  slug              String            @unique
  /// Visible title — used as the page's main heading and as SEO title fallback.
  title             String
  /// Internal/visible description — used in the admin list and as SEO
  /// description fallback. Optional.
  description       String?
  /// SEO `<title>` override. When null, the meta tag falls back to `title`.
  /// Use when the visible H1 should differ from the search-result title
  /// (e.g. brand-suffixed: "Promociones | ShopGood Perú").
  seoTitle          String?
  /// SEO meta description override. When null, falls back to `description`.
  /// Aim for ~150-160 chars for best SERP truncation.
  seoDescription    String?
  /// Open Graph image URL — preview shown when the page is shared on
  /// WhatsApp, Facebook, LinkedIn, Twitter, etc. Recommended 1200×630.
  seoImage          String?
  /// When true, emits <meta name="robots" content="noindex,nofollow">.
  /// Useful for internal / temporary landing pages that shouldn't appear
  /// in search engines.
  noIndex           Boolean           @default(false)
  active            Boolean           @default(true)
  createdBy         String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  /// Optimistic-locking version (Plan 18). Covers metadata, SEO, slug.
  /// Block-list reorders bump each touched PageBlock.version separately.
  version           Int               @default(0)
  pageBlocks        PageBlock[]
  /**
   * Themes that point to this page as their storefront home.
   */
  themesUsingAsHome Theme[]           @relation("ThemeHomePage")
  /**
   * Themes that point to this page as their cart-blocks wrapper.
   */
  themesUsingAsCart Theme[]           @relation("ThemeCartPage")
  /**
   * CodFormTemplates that point to this page as their thank-you destination.
   */
  codFormTemplates  CodFormTemplate[] @relation("CodFormThankYouPage")

  @@index([slug, active])
}

/// A named, hierarchical navigation menu (e.g. "main", "footer", "sidebar").
/// Plans 6/8 reference menus by slug to render the storefront's nav surfaces.
model Menu {
  id          String     @id @default(cuid())
  /// Slug used by the storefront to fetch the menu (e.g. "main", "footer-info").
  /// Must be unique. Lowercase + dashes only.
  slug        String     @unique
  /// Admin-facing display name.
  title       String
  description String?
  active      Boolean    @default(true)
  items       MenuItem[]
  createdBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  /// Optimistic-locking version (Plan 18). Covers menu metadata.
  /// Item reorders bump each touched MenuItem.version separately.
  version     Int        @default(0)

  @@index([slug, active])
}

model MenuItem {
  id           String     @id @default(cuid())
  menuId       String
  menu         Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  /// Self-referential parent. Max depth 3 — enforced server-side in
  /// actions/menus.ts (computeDepth + cycle check). The DB itself does
  /// not enforce a cap; depth is treated as a domain rule.
  parentId     String?
  parent       MenuItem?  @relation("MenuItemNesting", fields: [parentId], references: [id], onDelete: Cascade)
  children     MenuItem[] @relation("MenuItemNesting")
  position     Int
  /// Visible label shown in the menu.
  label        String
  /// Discriminator. Valid values:
  ///   PAGE, PRODUCT, CATEGORY, EXTERNAL_URL,
  ///   HOME, PRODUCTS_INDEX, COLLECTIONS_INDEX
  /// Stored as String (not enum) to avoid migration churn when adding new types.
  linkType     String
  /// Generic target reference, interpreted per linkType:
  ///   PAGE          → Page.id
  ///   PRODUCT       → Product.id
  ///   CATEGORY      → Category.id
  ///   EXTERNAL_URL  → null (uses externalUrl)
  ///   HOME / *_INDEX → null
  targetId     String?
  /// Used only when linkType == EXTERNAL_URL.
  externalUrl  String?
  openInNewTab Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  /// Optimistic-locking version (Plan 18).
  version      Int        @default(0)

  @@index([menuId, parentId, position])
}

model PageBlock {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  /// See CategoryBlock.type — string, validated against the registry.
  type      String
  position  Int
  content   Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Optimistic-locking version (Plan 18).
  version   Int      @default(0)

  @@index([pageId, position])
}

/// A storefront legal/policy document (Términos, Privacidad, Envíos,
/// Devoluciones, etc.). Modeled after Shopify's Policy concept: a single
/// rich-text body, separated from the page builder because policies are
/// long flat text and admins almost never want layout customization here.
/// Served at /politicas/<slug>.
model Policy {
  id             String   @id @default(cuid())
  /// URL slug used in /politicas/<slug>. Lowercase + dashes only.
  slug           String   @unique
  /// Visible H1 + nav title.
  title          String
  /// Full rich-text body (HTML produced by the Tiptap editor).
  body           String   @default("")
  active         Boolean  @default(true)
  /// SEO `<title>` override; null falls back to `title`.
  seoTitle       String?
  /// SEO meta description override.
  seoDescription String?
  /// Open Graph image URL.
  seoImage       String?
  /// When true, emit `<meta name="robots" content="noindex,nofollow">`.
  noIndex        Boolean  @default(false)
  /// Optional discriminator so the system can auto-link "the privacy policy"
  /// from checkout/footer regardless of slug. Stored as String (not enum)
  /// to allow new types without migrations. Examples:
  ///   TERMS, PRIVACY, SHIPPING, REFUND, OTHER
  policyType     String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  /// Optimistic-locking version (Plan 18). Policies are long-form Tiptap
  /// rich text — two admins editing the same policy simultaneously is the
  /// canonical lost-update scenario.
  version        Int      @default(0)

  @@index([slug, active])
  @@index([policyType])
}

/// A storefront "theme" — the umbrella under which all page templates
/// (home, cart, default product landing, static pages, …) eventually live.
/// Plan 4 only wires `defaultProductLandingTemplateId`; the other sections
/// are added in subsequent plans (5, 6, 7…).
model Theme {
  id                              String           @id @default(cuid())
  name                            String
  description                     String?
  /// Whether this theme is the currently active theme. Enforced as a
  /// singleton in code (only one theme has active=true at a time).
  active                          Boolean          @default(false)
  /// Default product landing template — used when a product has no
  /// landingTemplateId of its own. Null = no default; products without
  /// their own template render with no landing blocks.
  defaultProductLandingTemplateId String?
  defaultProductLandingTemplate   LandingTemplate? @relation(fields: [defaultProductLandingTemplateId], references: [id], onDelete: SetNull)
  /// Page rendered at the storefront root (/) when this theme is active.
  /// Null = fall back to the legacy hardcoded home layout (Plan 6).
  homePageId                      String?
  homePage                        Page?            @relation("ThemeHomePage", fields: [homePageId], references: [id], onDelete: SetNull)
  /// Page whose blocks are rendered above the storefront cart UI (Plan 10).
  /// Null = no blocks; cart UI shows alone.
  cartPageId                      String?
  cartPage                        Page?            @relation("ThemeCartPage", fields: [cartPageId], references: [id], onDelete: SetNull)
  /// Visual design tokens (colors, fonts, scale, radii) — Plan 11.
  /// Materialized into a single class-scoped stylesheet served via
  /// /api/themes/tokens.css; the storefront layout sets body class
  /// `theme-<slug>` to pick the right scope. Default {} means "use the
  /// system fallbacks" — the storefront keeps working even before any
  /// theme has tokens authored.
  ///
  /// Plan 13.1: tokens.colors is the legacy single palette and stays as
  /// the FALLBACK scheme. Multi-scheme palettes live in `colorSchemes`.
  tokens                          Json             @default("{}")
  /// Plan 13.1 — Shopify-style color schemes. Array of named palettes
  /// (`{ id, name, colors }`) so blocks can pick which scheme to render
  /// with via `content.style.colorSchemeId`. The first scheme acts as
  /// the default for blocks without an explicit pick. Empty array =
  /// fall back to the legacy `tokens.colors` palette.
  colorSchemes                    Json             @default("[]")
  /// Plan 16 — per-theme catalog of section types this theme exposes.
  /// Shape: { header?: string[], footer?: string[] }. Empty {} = permissive
  /// default (all registry types available). The customizer's
  /// AddSectionPanel intersects the registry with this catalog.
  sectionCatalog                  Json             @default("{}")
  /// Plan 16 — ordered Header / Footer sections that drive the storefront
  /// header and footer. Replaces the legacy single-Menu reference model
  /// (Phase E dropped the legacy headerMenuId/footerMenuId columns).
  sections                        ThemeSection[]
  createdBy                       String?
  createdAt                       DateTime         @default(now())
  updatedAt                       DateTime         @updatedAt
  /// Optimistic-locking version (Plan 18). Highest collision risk in the
  /// app: the customizer auto-saves on every keystroke / click, and a
  /// theme is the singleton most likely to be edited by multiple admins.
  version                         Int              @default(0)

  @@index([active])
}

model TemplateBlock {
  id         String          @id @default(cuid())
  templateId String
  template   LandingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  /// See CategoryBlock.type — string, validated against the registry.
  type       String
  position   Int
  content    Json            @default("{}")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  /// Optimistic-locking version (Plan 18).
  version    Int             @default(0)

  @@index([templateId, position])
}

/// Plan 16 — one section instance inside a theme's Header or Footer group.
/// Ordered by `position` within `(themeId, group)`. `content` follows the
/// same convention as LandingBlock.content: schema-defined fields at the
/// top level plus an optional `style` BlockStyle.
model ThemeSection {
  id        String              @id @default(cuid())
  themeId   String
  theme     Theme               @relation(fields: [themeId], references: [id], onDelete: Cascade)
  group     ThemeSectionGroup
  /// Type id from lib/theme-sections/registry.ts (e.g. "HEADER_MAIN").
  /// String — not enum — so adding a section type does not require migration.
  type      String
  position  Int
  content   Json                @default("{}")
  /// Toggle visibility from the customizer eye icon without destroying content.
  enabled   Boolean             @default(true)
  blocks    ThemeSectionBlock[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  /// Optimistic-locking version (Plan 18).
  version   Int                 @default(0)

  @@index([themeId, group, position])
}

/// Plan 16 — sub-block inside a ThemeSection (e.g. a LINK_COLUMN inside
/// FOOTER_COLUMNS, a MEGA_MENU_PANEL inside MEGA_MENU). Ordered by
/// `position` within its parent section.
model ThemeSectionBlock {
  id        String       @id @default(cuid())
  sectionId String
  section   ThemeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type      String
  position  Int
  content   Json         @default("{}")
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  /// Optimistic-locking version (Plan 18).
  version   Int          @default(0)

  @@index([sectionId, position])
}

enum ThemeSectionGroup {
  HEADER
  FOOTER
  PRODUCT
}

model CustomizableTemplate {
  id                String    @id @default(cuid())
  name              String
